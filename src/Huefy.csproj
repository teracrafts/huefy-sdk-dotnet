    <RootNamespace>Teracrafts.Huefy.Sdk</RootNamespace>
    <Version>1.0.0</Version>
    <AssemblyName>Teracrafts.Huefy.Sdk</AssemblyName>
    <PackageId>Teracrafts.Huefy.Sdk</PackageId>
    <Authors>teracrafts</Authors>
    <Description>Teracrafts Huefy SDK for .NET</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <RepositoryUrl>https://github.com/teracrafts/huefy-sdk</RepositoryUrl>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>
</Project>
